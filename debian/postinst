#!/bin/sh
# postinst — run after package installation
set -e

case "$1" in
    configure)
        # Ensure /opt/bin exists so the symlink installed by CMake is usable
        # immediately after dpkg unpacks the package.
        if [ ! -d /opt/bin ]; then
            mkdir -p /opt/bin
        fi

        # Attempt to create a 'ze' alias inside the package bin dir.
        # /opt/zedit/bin is not managed by any system package, so no
        # Breaks/Replaces stanza is needed.
        _created=0
        _dir=/opt/zedit/bin
        _link="$_dir/ze"
        _target_name="zedit"
        
        if [ ! -d "$_dir" ]; then
            echo "zedit: note: $_dir does not exist yet (may be upgraded); skipping ze alias creation" >&2
        elif [ -e "$_link" ] || [ -L "$_link" ]; then
            # Check if symlink already exists and points to zedit
            _existing_target=$(readlink "$_link" 2>/dev/null || true)
            if [ "$_existing_target" = "$_target_name" ]; then
                echo "zedit: ze alias already exists and is correct" >&2
                _created=1
            else
                echo "zedit: note: '$_link' already exists (→ ${_existing_target:-regular file}); not overwriting" >&2
            fi
        else
            # Shadowing check: warn if the system 'ze' is higher in PATH
            _sys_ze=$(command -v ze 2>/dev/null || true)
            if [ -n "$_sys_ze" ] && [ "$_sys_ze" != "$_link" ]; then
                echo "zedit: note: system 'ze' exists at '$_sys_ze'; new alias may be shadowed if that directory is earlier in PATH" >&2
            fi

            ln -sf "$_target_name" "$_link"
            echo "zedit: created alias: $_link → $_target_name"
            _created=1
        fi

        if [ "$_created" = "0" ]; then
            echo "zedit: could not create 'ze' alias automatically." >&2
            echo "zedit: run 'zedit --install-alias' as the target user to create it manually." >&2
        fi
        ;;
esac

#DEBHELPER#

exit 0
