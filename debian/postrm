#!/bin/sh
# postrm — run after package removal
set -e

case "$1" in
    purge)
        # Remove the config directory only on full purge
        if [ -d /etc/edit ]; then
            rm -rf /etc/edit
        fi
        ;;
    remove)
        # Remove the 'ed' alias symlinks we may have created in postinst.
        # Only remove if they still point to /usr/bin/edit (our binary).
        for _dir in /usr/local/bin /opt/bin; do
            _link="$_dir/ed"
            if [ -L "$_link" ]; then
                _target=$(readlink "$_link" 2>/dev/null || true)
                if [ "$_target" = "/usr/bin/edit" ] || [ "$_target" = "edit" ]; then
                    rm -f "$_link"
                    echo "edit: removed alias: $_link"
                fi
            fi
        done
        ;;
esac

#DEBHELPER#

exit 0
